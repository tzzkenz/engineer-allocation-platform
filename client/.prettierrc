{
  "plugins": ["@trivago/prettier-plugin-sort-imports"],
  "importOrder": [
    "^react$",
    "^react-dom(/.*)?$",
    "<THIRD_PARTY_MODULES>",
    "^@routes(/.*)?$",
    "^@pages(/.*)?$",
    "^@features(/.*)?$",
    "^@shared(/.*)?$",
    "^\\.\\.(?!/?$)",
    "^\\./"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true,
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "printWidth": 100,
  "trailingComma": "es5"
}
